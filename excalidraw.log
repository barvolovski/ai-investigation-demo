2026-02-08 15:18:27.583 [debug] Syncing to canvas: batch_create {"url":"http://localhost:3000/api/elements/batch","data":[{"id":"mldrqz27jh3yqgyohx","type":"rectangle","x":2600,"y":0,"width":580,"height":520,"backgroundColor":"#a5d8ff","strokeColor":"#1971c2","roughness":0,"createdAt":"2026-02-08T13:18:27.583Z","updatedAt":"2026-02-08T13:18:27.583Z","version":1},{"id":"mldrqz270a2dcednhxye","type":"text","x":2615,"y":10,"strokeColor":"#1971c2","text":"RULE DEFINITION (npm package)\n─────────────────────────────────\n@wix/ci-police-rule-{name}\n\nclass extends Rule {\n  check(cwd): RuleCheckResult\n  fix?(cwd): void          // optional\n}\n\nResults:\n  { severity: 'pass' }\n  { severity: 'error', message }\n  { severity: 'warning', message }\n  { severity: 'ignore' }\n  { violations: RuleViolation[] }\n\nRuleViolation:\n  id, title, severity, message?, deadline?","fontSize":13,"fontFamily":"3","createdAt":"2026-02-08T13:18:27.583Z","updatedAt":"2026-02-08T13:18:27.583Z","version":1},{"id":"mldrqz2710gm7g2oion","type":"rectangle","x":3230,"y":0,"width":460,"height":520,"backgroundColor":"#d0bfff","strokeColor":"#6741d9","roughness":0,"createdAt":"2026-02-08T13:18:27.583Z","updatedAt":"2026-02-08T13:18:27.583Z","version":1},{"id":"mldrqz27tmql1q2jaqq","type":"text","x":3245,"y":10,"strokeColor":"#6741d9","text":"RULE REGISTRATION (server-side)\n─────────────────────────────────\nRuleRegistration {\n  rule_name: string\n  promoted: { version }    // null = DEV\n  disabled: boolean\n  auto_autofix_enabled: boolean\n\n  metadata: {\n    description, ownership_tag\n    support_channel\n    rule_group: RuleGroups\n    optout_review_sla: days\n  }\n  resources: {\n    check_method: NPM_PACKAGE\n    enforcement: BREAK_BUILD\n               | BLOCK_ROLLOUT\n    subject: PROJECT | REPOSITORY\n  }\n}","fontSize":13,"fontFamily":"3","createdAt":"2026-02-08T13:18:27.583Z","updatedAt":"2026-02-08T13:18:27.583Z","version":1},{"id":"mldrqz27m9alqfhznn","type":"rectangle","x":2600,"