tedAt":"2026-02-08T11:15:15.594Z","version":1},{"id":"mldncjd3wln466nzfx","type":"arrow","x":550,"y":17970,"width":0,"height":40,"strokeColor":"#e11d48","strokeWidth":2,"createdAt":"2026-02-08T11:15:15.594Z","updatedAt":"2026-02-08T11:15:15.594Z","version":1},{"id":"mldncjd3kcnw2k6u579","type":"rectangle","x":100,"y":18020,"width":800,"height":80,"backgroundColor":"#fef3c7","strokeColor":"#d97706","strokeWidth":2,"createdAt":"2026-02-08T11:15:15.594Z","updatedAt":"2026-02-08T11:15:15.594Z","version":1},{"id":"mldncjd3nl4tkdygr8i","type":"text","x":150,"y":18035,"text":"Setup built → saved as MigrationPrompt (versioned: v1)\n→ Orchestrator suggests: Validate on Sample to test it","fontSize":15,"createdAt":"2026-02-08T11:15:15.594Z","updatedAt":"2026-02-08T11:15:15.594Z","version":1}],"count":13}
