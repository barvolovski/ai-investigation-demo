eatedAt":"2026-02-08T13:19:51.785Z","updatedAt":"2026-02-08T13:19:51.785Z","version":1},{"id":"mldrss15ybpabb4ra1","type":"text","x":3395,"y":2000,"strokeColor":"#495057","text":"DAEMON MODE\n─────────────────────────\nci-police daemon\n\nPersistent HTTP server\nAccepts check requests\nAvoids CLI startup per pkg\nUsed by Falcon plugin\n\nFaster for monorepos\nwith many packages","fontSize":12,"fontFamily":"3","createdAt":"2026-02-08T13:19:51.785Z","updatedAt":"2026-02-08T13:19:51.785Z","version":1}]}
